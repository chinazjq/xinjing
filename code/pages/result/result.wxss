.result { padding-bottom: 180rpx; background: var(--paper); }

/* ===== HERO PANEL ===== */
.hero-panel {
  padding: 56rpx 44rpx 64rpx;
  background: var(--ink);
  color: var(--paper);
  position: relative;
  overflow: hidden;
}

.hero-bg {
  position: absolute;
  right: -240rpx; top: -160rpx;
  width: 760rpx; height: 760rpx;
  border-radius: 50%;
  background: radial-gradient(circle at 35% 35%, var(--ember), rgba(201,79,30,0) 65%);
  opacity: 0.85;
  pointer-events: none;
}
.hero-ring {
  position: absolute;
  right: 80rpx; top: 220rpx;
  width: 200rpx; height: 200rpx;
  border: 1rpx solid rgba(244, 238, 227, 0.25);
  border-radius: 50%;
  pointer-events: none;
}

.hp-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 20rpx;
  letter-spacing: 5rpx;
  color: rgba(244, 238, 227, 0.6);
  position: relative;
  z-index: 1;
}
.hp-unlock { color: var(--ember); }

.hp-code {
  margin-top: 40rpx;
  font-size: 28rpx;
  font-style: italic;
  color: rgba(244, 238, 227, 0.55);
  letter-spacing: 4rpx;
  position: relative;
  z-index: 1;
}

.hp-title {
  margin-top: 8rpx;
  font-size: 92rpx;
  font-weight: 900;
  line-height: 1.05;
  letter-spacing: 0;
  color: var(--paper);
  position: relative;
  z-index: 1;
  word-break: break-all;
}

.hp-image-wrap {
  margin: 18rpx auto 0;
  width: 100%;
  height: 470rpx;
  overflow: visible;
  border: none;
  background: transparent;
  position: relative;
  z-index: 1;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}
.hp-image {
  width: 92%;
  height: 100%;
  display: block;
  filter: drop-shadow(0 28rpx 36rpx rgba(0, 0, 0, 0.32));
}
.hp-image-mbti { height: 500rpx; margin-top: 10rpx; }
.hp-image-sbti { height: 430rpx; margin-top: 18rpx; }
.hp-image-sbti .hp-image { width: 88%; }

.hp-tags {
  margin-top: 30rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  position: relative;
  z-index: 1;
}
.hp-tag {
  font-size: 18rpx;
  letter-spacing: 4rpx;
  color: rgba(244, 238, 227, 0.8);
  padding: 10rpx 20rpx;
  border: 1rpx solid rgba(244, 238, 227, 0.25);
  border-radius: 999rpx;
}

.hp-creed {
  margin-top: 48rpx;
  font-size: 28rpx;
  line-height: 1.75;
  color: rgba(244, 238, 227, 0.85);
  position: relative;
  z-index: 1;
}

/* ===== UNLOCK BANNER ===== */
.unlock-banner {
  margin: 40rpx 44rpx 0;
  padding: 32rpx 36rpx;
  background: var(--paper-warm);
  border: 1rpx solid var(--hairline);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
}
.ub-text { flex: 1; font-size: 26rpx; color: var(--stone-700); line-height: 1.5; }
.ub-btn { padding: 20rpx 28rpx; font-size: 26rpx; flex-shrink: 0; }

/* ===== SECTIONS ===== */
.section { padding: 50rpx 44rpx 0; border-top: 1rpx solid var(--hairline); margin-top: 50rpx; }
.section:first-of-type { border-top: none; margin-top: 0; }

.sec-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 36rpx;
}
.sh-title { font-size: 36rpx; font-weight: 900; color: var(--ink); letter-spacing: 0.02em; }
.sh-en { font-style: italic; font-weight: 400; color: var(--stone-500); font-size: 24rpx; margin-left: 10rpx; }
.sh-idx { font-size: 22rpx; letter-spacing: 5rpx; color: var(--stone-500); }

/* ===== DIMENSION BARS ===== */
.bars { display: flex; flex-direction: column; gap: 28rpx; }
.bar-row {}
.br-lbl {
  display: flex;
  justify-content: space-between;
  font-size: 20rpx;
  letter-spacing: 4rpx;
  color: var(--stone-700);
  margin-bottom: 12rpx;
}
.br-name { font-weight: 500; color: var(--ink); }
.br-pct {}
.br-track {
  height: 6rpx;
  background: var(--stone-100);
  border-radius: 999rpx;
  overflow: hidden;
}
.br-fill {
  height: 6rpx;
  background: var(--tc, var(--ink));
  border-radius: 999rpx;
  transition: width 0.6s;
}
.br-poles {
  display: flex;
  justify-content: space-between;
  margin-top: 8rpx;
  font-size: 24rpx;
  font-style: italic;
  color: var(--stone-500);
}

/* ===== STRENGTH / SHADOW GRID ===== */
.str-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  border: 1rpx solid var(--hairline);
}
.str-cell {
  padding: 32rpx;
  border-right: 1rpx solid var(--hairline);
  border-bottom: 1rpx solid var(--hairline);
}
.str-cell:nth-child(2n) { border-right: none; }
.str-cell:nth-last-child(-n+2) { border-bottom: none; }
.str-k { font-size: 18rpx; letter-spacing: 4rpx; color: var(--stone-500); margin-bottom: 14rpx; }
.str-v { font-size: 30rpx; font-weight: 700; color: var(--ink); line-height: 1.4; }
.shd-cell .str-v { color: var(--stone-700); }

/* ===== FAMOUS AVATAR CARDS ===== */
.famous-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
.fa-card {
  display: flex;
  align-items: flex-start;
  gap: 28rpx;
  border: 1rpx solid var(--hairline);
  border-radius: 28rpx;
  padding: 32rpx 28rpx;
  background: var(--paper-warm);
}
.fa-av {
  width: 88rpx; height: 88rpx;
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 32rpx; font-weight: 700;
  color: var(--paper);
  flex-shrink: 0;
}
.fa-body { flex: 1; min-width: 0; }
.fa-top { margin-bottom: 16rpx; }
.fa-nm { font-size: 32rpx; font-weight: 700; color: var(--ink); line-height: 1.3; }
.fa-role {
  font-size: 20rpx;
  color: var(--stone-500);
  letter-spacing: 2rpx;
  margin-top: 6rpx;
}
.fa-quote {
  font-size: 26rpx;
  color: var(--stone-700);
  line-height: 1.7;
  font-style: italic;
  border-left: 3rpx solid var(--tc, var(--ember));
  padding-left: 20rpx;
}

/* ===== PAIR GRID ===== */
.pair-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16rpx; }
.pair-cell {
  border: 1rpx solid var(--hairline);
  padding: 28rpx;
  border-radius: 28rpx;
}
.pair-cell.good { background: var(--ink); color: var(--paper); border-color: var(--ink); }
.pair-k { font-size: 18rpx; letter-spacing: 3rpx; color: var(--stone-500); margin-bottom: 12rpx; }
.pair-cell.good .pair-k { color: rgba(244, 238, 227, 0.6); }
.pair-v { font-size: 48rpx; font-weight: 900; color: var(--ink); }
.pair-cell.good .pair-v { color: var(--paper); }

/* ===== FOOT CTA ===== */
.foot-cta {
  position: fixed;
  left: 0; right: 0; bottom: 0;
  padding: 24rpx 44rpx 40rpx;
  background: linear-gradient(180deg, rgba(244, 238, 227, 0) 0%, var(--paper) 35%);
  display: flex;
  gap: 16rpx;
  align-items: center;
}
.btn-secondary {
  flex-shrink: 0;
  padding: 0 36rpx;
  height: 104rpx;
  border-radius: 999rpx;
  border: 1rpx solid var(--hairline);
  display: flex;
  align-items: center;
  font-size: 22rpx;
  letter-spacing: 4rpx;
  color: var(--stone-700);
}
.btn-share {
  flex: 1;
  height: 104rpx;
  border-radius: 999rpx;
  background: var(--ember);
  color: var(--paper);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 500;
  letter-spacing: 3rpx;
}

/* ===== DEEP INSIGHT PANEL ===== */
.insight-panel {
  position: relative;
  overflow: hidden;
  background: var(--ink);
  margin-top: 50rpx;
  padding: 64rpx 44rpx 72rpx;
}

/* Floating orbs for flowing-sand effect */
.insight-orb {
  position: absolute;
  border-radius: 50%;
  background: radial-gradient(circle, var(--tc, #C94F1E) 0%, transparent 68%);
  opacity: 0.22;
  pointer-events: none;
}
.io-1 {
  width: 480rpx; height: 480rpx;
  top: -120rpx; right: -80rpx;
  animation: io-drift-1 9s ease-in-out infinite;
}
.io-2 {
  width: 360rpx; height: 360rpx;
  bottom: -100rpx; left: -60rpx;
  animation: io-drift-2 13s ease-in-out infinite;
}
.io-3 {
  width: 260rpx; height: 260rpx;
  top: 45%; left: 38%;
  opacity: 0.14;
  animation: io-drift-3 11s ease-in-out infinite;
}

@keyframes io-drift-1 {
  0%, 100% { transform: translate(0, 0) scale(1); }
  30%  { transform: translate(-20px, 16px) scale(1.08); }
  65%  { transform: translate(14px, -22px) scale(0.93); }
}
@keyframes io-drift-2 {
  0%, 100% { transform: translate(0, 0) scale(1); }
  35%  { transform: translate(28px, -16px) scale(1.12); }
  70%  { transform: translate(-12px, 22px) scale(0.9); }
}
@keyframes io-drift-3 {
  0%, 100% { transform: translate(0, 0) scale(1); }
  40%  { transform: translate(-18px, -24px) scale(1.18); }
  80%  { transform: translate(22px, 16px) scale(0.84); }
}

/* Content inside the insight panel */
.insight-inner { position: relative; z-index: 1; }

.insight-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}
.insight-label {
  font-size: 20rpx;
  letter-spacing: 6rpx;
  color: rgba(244, 238, 227, 0.45);
}
.insight-idx {
  font-size: 22rpx;
  letter-spacing: 5rpx;
  color: rgba(244, 238, 227, 0.3);
}

.insight-title {
  font-size: 52rpx;
  font-weight: 900;
  color: var(--paper);
  line-height: 1.1;
  margin-bottom: 36rpx;
}

.insight-divider {
  width: 48rpx;
  height: 3rpx;
  background: var(--tc, #C94F1E);
  border-radius: 999rpx;
  margin-bottom: 44rpx;
  opacity: 0.85;
}

.insight-para {
  font-size: 28rpx;
  line-height: 1.85;
  color: rgba(244, 238, 227, 0.78);
  margin-bottom: 32rpx;
}
.insight-para:last-child { margin-bottom: 0; }
