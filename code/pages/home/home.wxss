.home {
  padding: 0 40rpx 200rpx;
  min-height: 100vh;
  position: relative;
}

/* Hero */
.hero-block { padding: 60rpx 0 40rpx; }
.greet { font-size: 22rpx; color: var(--stone-500); letter-spacing: 5rpx; margin-bottom: 24rpx; }
.hero-h1 {
  font-size: 72rpx;
  font-weight: 900;
  line-height: 1.05;
  letter-spacing: -0.01em;
  color: var(--ink);
}
.ember-text { color: var(--ember); font-style: italic; margin-left: 8rpx; }
.hero-sub {
  font-size: 26rpx;
  color: var(--stone-700);
  margin-top: 24rpx;
  line-height: 1.7;
}

/* Section heading */
.section-mark {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin: 48rpx 0 28rpx;
}
.sm-title { font-size: 44rpx; font-weight: 900; letter-spacing: 0.02em; color: var(--ink); }
.sm-en { font-style: italic; font-weight: 400; color: var(--stone-500); font-size: 30rpx; }
.sm-more { font-size: 22rpx; color: var(--stone-500); letter-spacing: 3rpx; padding: 16rpx 0 16rpx 20rpx; }

/* Card list */
.card-list { display: flex; flex-direction: column; gap: 20rpx; }

.card {
  position: relative;
  padding: 36rpx 40rpx;
  border-radius: 44rpx;
  display: grid;
  grid-template-columns: 1fr 128rpx;
  gap: 24rpx;
  align-items: center;
  overflow: hidden;
  border: 1rpx solid var(--hairline-dim);
  background: var(--paper-warm);
}
.card-hover { opacity: 0.82; }

.card-inner { display: flex; flex-direction: column; min-width: 0; }

.c-idx { font-size: 20rpx; color: var(--stone-500); letter-spacing: 4rpx; margin-bottom: 12rpx; }
.c-ttl {
  font-size: 44rpx;
  font-weight: 900;
  line-height: 1.15;
  letter-spacing: 0.02em;
  color: var(--ink);
}
.c-en { font-style: italic; font-weight: 400; color: var(--stone-500); font-size: 26rpx; margin-left: 6rpx; }
.c-line { font-size: 24rpx; color: var(--stone-700); margin-top: 12rpx; line-height: 1.55; }
.c-meta { display: flex; align-items: center; gap: 10rpx; margin-top: 18rpx; font-size: 22rpx; color: var(--stone-500); letter-spacing: 2rpx; }
.c-dot { color: var(--stone-300); }
.c-hot { color: var(--ember); }

/* Colored glyph circle */
.c-glyph {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  background: var(--cg, var(--ink));
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 52rpx;
  font-weight: 900;
  color: var(--paper);
  flex-shrink: 0;
}

/* Hero featured card (SBTI) */
.card-hero {
  grid-template-columns: 1fr;
  background: var(--ink) !important;
  color: var(--paper);
  min-height: 320rpx;
  border-color: transparent;
}
.card-hero .c-idx { color: rgba(244, 238, 227, 0.6); }
.card-hero .c-ttl { font-size: 60rpx; color: var(--paper); }
.card-hero .c-en { color: rgba(244, 238, 227, 0.5); }
.card-hero .c-line { color: rgba(244, 238, 227, 0.72); font-size: 26rpx; }
.card-hero .c-cta {
  margin-top: 36rpx;
  font-size: 24rpx;
  letter-spacing: 4rpx;
  color: var(--ember);
}

/* Decorative circle on hero card */
.glyph-bg {
  position: absolute;
  right: -40rpx;
  bottom: -60rpx;
  width: 360rpx;
  height: 360rpx;
  border: 1rpx solid rgba(244, 238, 227, 0.25);
  border-radius: 50%;
  pointer-events: none;
}
.glyph-bg::before {
  content: "";
  position: absolute;
  inset: 24rpx;
  background: radial-gradient(circle at 30% 30%, rgba(201, 79, 30, 0.85), transparent 70%);
  border-radius: 50%;
  opacity: 0.9;
}

/* ===== WISDOM CARD ===== */
.wisdom-card {
  position: relative;
  border-radius: 44rpx;
  overflow: hidden;
  padding: 52rpx 44rpx 44rpx;
  background: var(--ink);
  color: var(--paper);
  min-height: 360rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}
.wc-ring {
  position: absolute;
  border-radius: 50%;
  border: 1rpx solid rgba(244, 238, 227, 0.18);
  pointer-events: none;
}
.wc-ring-1 { width: 440rpx; height: 440rpx; right: -160rpx; top: -160rpx; }
.wc-ring-2 { width: 260rpx; height: 260rpx; right: -60rpx; top: -40rpx; opacity: 0.5; }

.wisdom-ember .wc-ring-1 { background: radial-gradient(circle at 30% 30%, rgba(201,79,30,0.45), transparent 65%); }
.wisdom-jade   .wc-ring-1 { background: radial-gradient(circle at 30% 30%, rgba(47,94,79,0.55), transparent 65%); }
.wisdom-amber  .wc-ring-1 { background: radial-gradient(circle at 30% 30%, rgba(239,159,39,0.45), transparent 65%); }
.wisdom-iris   .wc-ring-1 { background: radial-gradient(circle at 30% 30%, rgba(127,119,221,0.55), transparent 65%); }
.wisdom-sky    .wc-ring-1 { background: radial-gradient(circle at 30% 30%, rgba(55,138,221,0.50), transparent 65%); }
.wisdom-plum   .wc-ring-1 { background: radial-gradient(circle at 30% 30%, rgba(83,74,183,0.55), transparent 65%); }
.wisdom-rose   .wc-ring-1 { background: radial-gradient(circle at 30% 30%, rgba(212,83,126,0.50), transparent 65%); }

.wc-inner { position: relative; z-index: 1; }
.wc-label {
  font-size: 18rpx;
  letter-spacing: 5rpx;
  color: rgba(244,238,227,0.45);
  margin-bottom: 28rpx;
}
.wc-text {
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1.75;
  color: var(--paper);
  letter-spacing: 0.04em;
}
.wc-meta {
  font-size: 22rpx;
  color: rgba(244,238,227,0.55);
  letter-spacing: 2rpx;
  margin-top: 28rpx;
}
.wc-dot { color: rgba(244,238,227,0.3); }
.wc-src { font-style: italic; }
.wc-date {
  font-size: 18rpx;
  color: rgba(244,238,227,0.3);
  letter-spacing: 4rpx;
  margin-top: 36rpx;
  position: relative; z-index: 1;
}

/* Section button hover */
.sm-more-hover { opacity: 0.6; }

/* Footer */
.footer {
  text-align: center;
  font-size: 22rpx;
  color: var(--stone-500);
  letter-spacing: 6rpx;
  margin-top: 80rpx;
}
