.quiz { min-height: 100vh; padding: 20rpx 50rpx 60rpx; display: flex; flex-direction: column; }

.topbar { display: flex; align-items: center; gap: 20rpx; padding: 30rpx 0; }
.progress { flex: 1; height: 2rpx; background: var(--hairline); position: relative; }
.progress-bar { height: 2rpx; background: var(--tc, var(--ink)); transition: width .3s; }
.progress-text { font-size: 24rpx; color: var(--stone-500); letter-spacing: 2rpx; }
.progress-text .slash { margin: 0 6rpx; }

.q-block { margin-top: 80rpx; min-height: 260rpx; }
.q-idx { font-size: 40rpx; color: var(--tc, var(--ink)); opacity: .5; }
.q-text { font-size: 48rpx; line-height: 1.5; color: var(--ink); margin-top: 16rpx; }

.opts { margin-top: 80rpx; display: flex; flex-direction: column; gap: 24rpx; }
.opt {
  padding: 36rpx 30rpx;
  border: 1rpx solid var(--hairline);
  background: var(--paper-warm);
  display: flex;
  gap: 24rpx;
  align-items: flex-start;
  transition: transform .15s, background .15s;
}
.opt-hover { background: var(--tb, var(--paper-deep)); transform: scale(.99); }
.opt-mark { font-size: 24rpx; color: var(--tc, var(--ink)); letter-spacing: 2rpx; padding-top: 8rpx; flex-shrink: 0; }
.opt-text { font-size: 30rpx; color: var(--ink); line-height: 1.6; flex: 1; }
.opt-div { text-align: center; color: var(--stone-500); font-size: 26rpx; margin: 10rpx 0; }

.likert { margin-top: 100rpx; }
.likert-labels { display: flex; justify-content: space-between; font-size: 20rpx; color: var(--stone-500); margin-bottom: 40rpx; }
.likert-dots { display: flex; justify-content: space-between; align-items: center; padding: 20rpx 0; }
.ldot { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 12rpx; }
.ldot-inner { border: 2rpx solid var(--tc, var(--ink)); border-radius: 50%; background: transparent; transition: background .2s; }
.ldot-hover .ldot-inner { background: var(--tc, var(--ink)); }
.ldot-num { font-size: 22rpx; color: var(--stone-500); }

.footer { margin-top: auto; padding: 40rpx 0 20rpx; }
.back { font-size: 22rpx; color: var(--stone-500); letter-spacing: 4rpx; padding: 20rpx 0; display: block; }
